<?xml version="1.0" encoding="utf-8"?>
<!-- Translucent glass pill sitting over the onboarding gradient (Figma). -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:colorControlHighlight">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/onboarding_glass" />
            <stroke
                android:width="1dp"
                android:color="@color/onboarding_glass_stroke" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</ripple>
