<?xml version="1.0" encoding="utf-8"?>
<!-- Glass pill field for the handle input, matching the onboarding buttons. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@color/onboarding_glass" />
    <stroke
        android:width="1dp"
        android:color="@color/onboarding_glass_stroke" />
    <corners android:radius="28dp" />
    <padding
        android:left="22dp"
        android:top="4dp"
        android:right="22dp"
        android:bottom="4dp" />
</shape>
