<?xml version="1.0" encoding="utf-8"?>
<!--
    Fades in over the blue gradient on the "You're all set" step: transparent
    across the top so the blue remains visible, becoming opaque near-white
    (light) / near-black (dark) toward the bottom.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:angle="270"
        android:startColor="@color/onboarding_settle_fade"
        android:centerColor="@color/onboarding_settle_fade"
        android:endColor="@color/oneui_bg"
        android:type="linear" />
</shape>
