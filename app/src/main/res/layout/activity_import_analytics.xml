<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.widget.AdaptiveCoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/import_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/import_gradient_bg">

    <LinearLayout
        android:id="@+id/import_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/import_step_intro"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingTop="112dp"
                    android:paddingEnd="28dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/import_data_from_x"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="1dp"
                        android:layout_height="132dp" />

                    <LinearLayout
                        android:id="@+id/import_analytics_row"
                        android:layout_width="match_parent"
                        android:layout_height="104dp"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_import_analytics" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sec"
                                android:text="@string/import_get_stats_title"
                                android:textColor="@color/oneui_text_primary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/import_analytics_summary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sec"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/import_get_stats_summary"
                                android:textColor="@color/oneui_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="128dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_import_premium" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sec"
                                android:text="@string/import_premium_title"
                                android:textColor="@color/oneui_text_primary"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sec"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/import_premium_summary"
                                android:textColor="@color/oneui_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="123dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_import_accuracy" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sec"
                                android:text="@string/import_accuracy_title"
                                android:textColor="@color/oneui_text_primary"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sec"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/import_accuracy_summary"
                                android:textColor="@color/oneui_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:id="@+id/import_step_confirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="72dp"
                android:paddingEnd="28dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/import_account_avatar"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/avatar_twidget"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/import_account_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="sec"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:fontFamily="sec"
                    android:text="@string/import_range"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/import_range_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="sec"
                    android:gravity="center"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="sec"
                    android:text="@string/import_detected_followers"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/import_detected_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="sec"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="sec"
                    android:text="@string/import_metrics_detected"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/import_metrics_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="sec"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/import_step_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="112dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sec"
                    android:text="@string/importing"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/import_spinner"
                    android:layout_width="118dp"
                    android:layout_height="118dp"
                    android:layout_marginTop="108dp"
                    android:src="@drawable/oneui_spinner" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/import_step_success"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sec"
                    android:text="@string/imported"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="42sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/import_step_failure"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="244dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sec"
                    android:text="@string/not_imported"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/import_failure_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="88dp"
                    android:fontFamily="sec"
                    android:gravity="center"
                    android:text="@string/import_failure_default"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/import_failure_counts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="sec"
                        android:text="@string/import_stored_followers"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/import_stored_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sec"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="sec"
                        android:text="@string/import_detected_followers"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/import_failure_detected_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sec"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/import_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="28dp"
            android:paddingTop="8dp"
            android:paddingEnd="28dp"
            android:paddingBottom="24dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/import_secondary_button"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/onboarding_glass_button_bg"
                android:fontFamily="sec"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/oneui_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/import_primary_button"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/import_primary_button_bg"
                android:fontFamily="sec"
                android:text="@string/import_action"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</dev.oneuiproject.oneui.widget.AdaptiveCoordinatorLayout>
