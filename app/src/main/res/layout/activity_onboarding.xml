<?xml version="1.0" encoding="utf-8"?>
<!--
    Plain gradient-backed container (no ToolbarLayout) so the onboarding
    backdrop is edge-to-edge at any screen size. A settle overlay sits above the
    gradient (below the content) to drain the blue on the final step. Scroll
    fills the middle, footer pins to the bottom.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_gradient_bg">

    <!-- Background layers fill full-bleed (under the status bar); only the
         content below insets itself, so the settle overlay covers the status
         bar area too and leaves no seam. -->
    <View
        android:id="@+id/done_fade_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/onboarding_settle_overlay"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/onboarding_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fillViewport="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="520dp"
                android:paddingStart="@dimen/onboarding_side_padding"
                android:paddingTop="12dp"
                android:paddingEnd="@dimen/onboarding_side_padding"
                android:paddingBottom="24dp">

                <!-- Step 1 · Welcome -->
                <LinearLayout
                    android:id="@+id/step_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="120dp">

                    <TextView
                        android:id="@+id/overview_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/onboarding_overview_title"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="34sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Step 2 · Handle -->
                <LinearLayout
                    android:id="@+id/step_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="96dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/onboarding_profile_title"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:text="@string/onboarding_profile_summary"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/username_input"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="40dp"
                        android:background="@drawable/onboarding_input_bg"
                        android:fontFamily="sec"
                        android:hint="@string/onboarding_handle_hint"
                        android:imeOptions="actionDone"
                        android:includeFontPadding="false"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="?android:textColorPrimary"
                        android:textColorHint="?android:textColorSecondary"
                        android:textSize="19sp" />

                    <CheckBox
                        android:id="@+id/share_history_checkbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="36dp"
                        android:fontFamily="sec"
                        android:text="@string/share_history"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sec"
                        android:lineSpacingExtra="2dp"
                        android:paddingStart="34dp"
                        android:paddingEnd="0dp"
                        android:text="@string/share_history_onboarding_summary"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Step 3 · Add widget -->
                <LinearLayout
                    android:id="@+id/step_widgets"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="48dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/add_widget"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:text="@string/onboarding_profile_summary"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp" />

                    <!-- Preview centres in the space between subtitle and the
                         footer while it cycles through widget sizes. -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">

                        <FrameLayout
                            android:id="@+id/widget_preview_host"
                            android:layout_width="280dp"
                            android:layout_height="130dp"
                            android:layout_gravity="center">

                            <ImageView
                                android:id="@+id/widget_preview_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Step 4 · Done (title centred; fades up into place) -->
                <LinearLayout
                    android:id="@+id/step_done"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/onboarding_done_title"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sec"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/onboarding_done_summary"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/onboarding_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/onboarding_side_padding"
            android:paddingTop="8dp"
            android:paddingEnd="@dimen/onboarding_side_padding"
            android:paddingBottom="24dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/primary_button"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/onboarding_glass_button_bg"
                android:fontFamily="sec"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:stateListAnimator="@null"
                android:text="@string/continue_button"
                android:textAllCaps="false"
                android:textColor="?android:textColorPrimary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/secondary_button"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/onboarding_glass_button_bg"
                android:fontFamily="sec"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:stateListAnimator="@null"
                android:text="@string/advanced_options"
                android:textAllCaps="false"
                android:textColor="?android:textColorPrimary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
