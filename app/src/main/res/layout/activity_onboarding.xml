<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/onboarding_toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:expandable="true"
    app:expanded="false"
    app:mainRoundedCorners="none"
    app:title="@string/onboarding_title">

    <ScrollView
        android:id="@+id/onboarding_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?roundedCornerColor"
        android:fillViewport="true"
        app:layout_location="main_content">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="156dp">

            <LinearLayout
                android:id="@+id/step_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@drawable/config_preview_bg">

                    <FrameLayout
                        android:id="@+id/hero_preview_host"
                        android:layout_width="280dp"
                        android:layout_height="128dp"
                        android:layout_gravity="center">

                        <ImageView
                            android:id="@+id/hero_preview_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="fitXY" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="sec"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/onboarding_overview_title"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <dev.oneuiproject.oneui.widget.OnboardingTipsItemView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:icon="@drawable/ic_oneui_refresh"
                    app:summary="@string/onboarding_tip_stats_summary"
                    app:title="@string/onboarding_tip_stats_title" />

                <dev.oneuiproject.oneui.widget.OnboardingTipsItemView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_oneui_widget_outline"
                    app:summary="@string/onboarding_tip_widgets_summary"
                    app:title="@string/onboarding_tip_widgets_title" />

                <dev.oneuiproject.oneui.widget.OnboardingTipsItemView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_oneui_profile"
                    app:summary="@string/onboarding_tip_accounts_summary"
                    app:title="@string/onboarding_tip_accounts_title" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/step_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sec"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/onboarding_profile_title"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sec"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/onboarding_profile_summary"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="sec"
                    android:includeFontPadding="false"
                    android:text="@string/onboarding_username_label"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/username_input"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/onboarding_input_bg"
                    android:fontFamily="sec"
                    android:hint="@string/profile_username_hint"
                    android:imeOptions="actionDone"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorSecondary"
                    android:textSize="19sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/step_widgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sec"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/onboarding_widgets_summary"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="16sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/config_preview_bg">

                    <FrameLayout
                        android:id="@+id/widget_preview_host"
                        android:layout_width="142dp"
                        android:layout_height="156dp"
                        android:layout_gravity="center">

                        <ImageView
                            android:id="@+id/widget_preview_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="fitXY" />
                    </FrameLayout>
                </FrameLayout>

                <dev.oneuiproject.oneui.widget.OnboardingTipsItemView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:icon="@drawable/ic_oneui_widget_outline"
                    app:summary="@string/onboarding_widgets_home_summary"
                    app:title="@string/onboarding_widgets_home_title" />

                <dev.oneuiproject.oneui.widget.OnboardingTipsItemView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_oneui_lock_outline"
                    app:summary="@string/onboarding_widgets_lock_summary"
                    app:title="@string/onboarding_widgets_lock_title" />

                <CheckBox
                    android:id="@+id/share_history_checkbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sec"
                    android:text="@string/share_history"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="33dp"
                    android:paddingEnd="0dp"
                    android:fontFamily="sec"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/share_history_onboarding_summary"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/onboarding_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?roundedCornerColor"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        app:layout_location="footer">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/secondary_button"
            style="@style/OneUI.ContainedButton"
            android:theme="@style/OneUI.ContainedButtonTheme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:text="@string/advanced_options"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/primary_button"
            style="@style/OneUI.ContainedButton"
            android:theme="@style/OneUI.ContainedPrimaryColorButtonTheme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:text="@string/continue_button" />
    </LinearLayout>
</dev.oneuiproject.oneui.layout.ToolbarLayout>
