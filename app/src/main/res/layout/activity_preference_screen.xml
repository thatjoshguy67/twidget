<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/preference_toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:expandable="true"
    app:expanded="false"
    app:handleInsets="false"
    app:mainRoundedCorners="top"
    app:showNavButtonAsBack="true"
    app:title="@string/settings">

    <FrameLayout
        android:id="@+id/preference_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?roundedCornerColor"
        app:layout_location="main_content" />
</dev.oneuiproject.oneui.layout.ToolbarLayout>
