<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sec"
        android:lineSpacingExtra="3dp"
        android:text="@string/x_api_explainer"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/x_api_portal_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="?android:selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sec"
            android:includeFontPadding="false"
            android:text="@string/x_developer_portal"
            android:textColor="@color/oneui_accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="5dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_oui_open"
            app:tint="@color/oneui_accent" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sec"
        android:includeFontPadding="false"
        android:text="@string/x_api_key"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/x_api_key_input"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/onboarding_input_bg"
        android:fontFamily="sec"
        android:hint="@string/x_api_key"
        android:imeOptions="actionNext"
        android:includeFontPadding="false"
        android:inputType="text"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="?android:textColorPrimary"
        android:textColorHint="?android:textColorSecondary"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sec"
        android:includeFontPadding="false"
        android:text="@string/x_api_secret"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/x_api_secret_input"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/onboarding_input_bg"
        android:fontFamily="sec"
        android:hint="@string/x_api_secret"
        android:imeOptions="actionDone"
        android:includeFontPadding="false"
        android:inputType="textPassword"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="?android:textColorPrimary"
        android:textColorHint="?android:textColorSecondary"
        android:textSize="16sp" />
</LinearLayout>
