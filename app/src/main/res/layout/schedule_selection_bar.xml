<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.widget.RoundedLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/schedule_selection_bar"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="20dp"
    android:background="@drawable/schedule_toolbar_floating_bg"
    android:elevation="8dp"
    android:gravity="center"
    android:minWidth="272dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp"
    android:visibility="gone"
    app:roundedCorners="all">

    <LinearLayout
        android:id="@+id/schedule_selection_pin"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:minHeight="56dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/schedule_selection_pin_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/schedule_pin"
            app:srcCompat="@drawable/ic_oui_pin_outline"
            app:tint="@color/oneui_text_primary" />

        <TextView
            android:id="@+id/schedule_selection_pin_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/schedule_pin"
            android:textColor="@color/oneui_text_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_selection_duplicate"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:minHeight="56dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/schedule_duplicate"
            app:srcCompat="@drawable/ic_oui_copy_outline"
            app:tint="@color/oneui_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/schedule_duplicate"
            android:textColor="@color/oneui_text_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_selection_delete"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:minHeight="56dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/delete"
            app:srcCompat="@drawable/ic_oui_delete_outline"
            app:tint="@color/metric_red" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/delete"
            android:textColor="@color/metric_red"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_selection_more"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:minHeight="56dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/schedule_more_actions"
            app:srcCompat="@drawable/ic_oui_more"
            app:tint="@color/oneui_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/schedule_more"
            android:textColor="@color/oneui_text_primary"
            android:textSize="11sp" />
    </LinearLayout>
</dev.oneuiproject.oneui.widget.RoundedLinearLayout>
