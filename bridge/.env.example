PORT=8787
CACHE_TTL_SECONDS=900
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=60
EXPENSIVE_RATE_LIMIT_MAX=12
RATE_LIMIT_MAX_IPS=10000
MAX_CACHE_ENTRIES=1000
MAX_CONCURRENT_UPSTREAM=8
OAUTH_MAX_PENDING=1000
TRUST_PROXY_HOPS=1
ANALYTICS_TTL_SECONDS=2700
ANALYTICS_POST_COUNT=100
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=15000
KEEP_ALIVE_TIMEOUT_MS=5000
MAX_HEADERS_COUNT=100
MAX_REQUESTS_PER_SOCKET=100

# Optional shared state. When REDIS_URL is set, startup fails if Redis cannot
# be reached and request limiting fails closed during an outage.
# REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=3000

HISTORY_MAX_DAYS=400
HISTORY_MAX_ACCOUNTS=250
HISTORY_REGISTRATIONS_PER_HOUR=30
HISTORY_REFRESH_MINUTES=60
HISTORY_CLIENT_BACKFILL=0
WAYBACK_BACKFILL=0
WAYBACK_MAX_SNAPSHOTS=12
WAYBACK_MAX_CONCURRENT=1
# json is safe for one local/single-replica process. Use postgres before
# increasing replica count. PostgreSQL schema creation is automatic.
HISTORY_BACKEND=json
# HISTORY_STORE_PATH=/data/twidget-history.json
# HISTORY_DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
HISTORY_DATABASE_POOL_MAX=10
HISTORY_DATABASE_CONNECT_TIMEOUT_MS=5000
HISTORY_DATABASE_IDLE_TIMEOUT_MS=30000
HISTORY_DATABASE_STATEMENT_TIMEOUT_MS=10000

# Retention is disabled by default to avoid silently deleting existing data.
# Set either value to a positive day count to opt in. Inactive-account age is
# based on client access/registration, not the bridge's scheduled refreshes.
HISTORY_SAMPLE_RETENTION_DAYS=0
HISTORY_INACTIVE_ACCOUNT_DAYS=0
HISTORY_PRUNE_HOURS=24

# Optional bearer token for every data endpoint. Health and OAuth handoff
# routes remain public. Use a long random value on private/self-hosted bridges.
# BRIDGE_API_TOKEN=

# Separate operator credential for DELETE /admin/history/:username. Do not
# distribute this token to app clients.
# HISTORY_ADMIN_TOKEN=

# Browser CORS is disabled unless an exact origin is configured.
# CORS_ALLOW_ORIGIN=https://example.com

# Official X enrichment is private by default even when a bearer is present.
# X_BEARER_TOKEN=
# PUBLIC_OFFICIAL_API=0

# OAuth is disabled unless explicitly enabled with a fixed callback URL.
# X_OAUTH_ENABLED=0
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_CALLBACK_URL=https://bridge.example.com/oauth/x/callback
# X_OAUTH_SCOPES=users.read tweet.read offline.access
# TWIDGET_ANDROID_RETURN_URI=twidget://oauth/x
